{
  "name": "pgrest-lambda",
  "version": "0.2.0",
  "description": "A serverless REST API for any PostgreSQL database",
  "type": "module",
  "exports": {
    ".": "./src/index.mjs",
    "./contribution": "./src/rest/openapi-contribution.mjs"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yoshuacas/pgrest-lambda.git"
  },
  "files": [
    "src",
    "policies",
    "lambda.mjs",
    "dev.mjs",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "postgrest",
    "postgresql",
    "lambda",
    "serverless",
    "rest-api",
    "aurora",
    "dsql",
    "supabase-compatible"
  ],
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.0.0",
    "@aws-sdk/client-sesv2": "^3.0.0",
    "@aws-sdk/dsql-signer": "^3.0.0",
    "@cedar-policy/cedar-wasm": "^4.9.1",
    "better-auth": "^1.0.0",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.13.0"
  },
  "scripts": {
    "test": "node --experimental-test-module-mocks --test 'src/**/*.test.mjs'"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.104.1"
  }
}
