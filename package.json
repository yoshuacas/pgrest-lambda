{
  "name": "pgrest-lambda",
  "version": "0.1.1",
  "description": "A serverless REST API for any PostgreSQL database",
  "type": "module",
  "exports": {
    ".": "./src/index.mjs",
    "./contribution": "./src/rest/openapi-contribution.mjs",
    "./aws-sam": "./deploy/aws-sam/authorizer.mjs"
  },
  "bin": {
    "pgrest-lambda": "bin/pgrest-lambda.mjs"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yoshuacas/pgrest-lambda.git"
  },
  "files": [
    "src",
    "bin",
    "deploy",
    "policies",
    "README.md",
    "LICENSE",
    "!**/__tests__/**",
    "!**/*.test.mjs",
    "!**/*.integration.test.mjs"
  ],
  "keywords": [
    "postgrest",
    "postgresql",
    "lambda",
    "serverless",
    "rest-api",
    "aurora",
    "dsql",
    "supabase-compatible"
  ],
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.0.0",
    "@aws-sdk/client-sesv2": "^3.0.0",
    "@aws-sdk/dsql-signer": "^3.0.0",
    "@cedar-policy/cedar-wasm": "^4.9.1",
    "better-auth": "^1.0.0",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.13.0"
  },
  "scripts": {
    "dev": "node bin/pgrest-lambda.mjs dev",
    "refresh": "node bin/pgrest-lambda.mjs refresh",
    "generate-key": "node bin/pgrest-lambda.mjs generate-key",
    "migrate-auth": "node bin/pgrest-lambda.mjs migrate-auth",
    "test": "node --experimental-test-module-mocks --test 'src/**/*.test.mjs' 'deploy/**/*.test.mjs'",
    "test:integration": "node --test --test-concurrency=1 'tests/integration/**/*.test.mjs'",
    "test:e2e": "node --test --test-concurrency=1 'tests/e2e/**/*.test.mjs'",
    "test:all": "npm test && npm run test:integration && npm run test:e2e",
    "test:bump-better-auth": "echo 'Usage: npm i better-auth@<version> && npm run test:all' && exit 1",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "vitepress": "^1.5.0",
    "vitepress-plugin-llms": "^1.12.1"
  }
}
