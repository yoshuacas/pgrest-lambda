{
  "name": "implementer",
  "description": "Implementation agent that picks tasks from the tasks folder, implements them following project conventions, and commits the results.",
  "prompt": "file://./implementer-prompt.md",
  "tools": ["*"],
  "allowedTools": [
    "read",
    "write",
    "code*",
    "grep",
    "glob",
    "fs_*"
  ],
  "toolsSettings": {
    "execute_bash": {
      "allowedCommands": [
        "git add",
        "git commit",
        "git status",
        "git diff",
        "rring end-task"
      ]
    }
  },
  "resources": [
    "file://AGENTS.md",
    "file://tasks/README.md",
    "skill://.kiro/skills/*/SKILL.md",
    "skill://~/.kiro/skills/*/SKILL.md",
    "file://.kiro/steering/**/*.md"
  ],
  "welcomeMessage": "Ready to pick up a task from tasks/ and implement it."
}
