{
  "name": "dispatcher",
  "description": "Task dispatcher that claims the next task and routes it to the appropriate implementation agent based on the task's Agent field.",
  "prompt": "file://./dispatcher-prompt.md",
  "tools": ["*"],
  "allowedTools": [
    "read",
    "write",
    "code*",
    "grep",
    "glob",
    "fs_*",
    "execute_bash"
  ],
  "toolsSettings": {
    "execute_bash": {
      "allowedCommands": [
        "git status",
        "git diff",
        "git config",
        "git rev-parse",
        "rring run-agent",
        "rring status",
        "rring maintained"
      ]
    }
  },
  "resources": [
    "file://AGENTS.md",
    "file://tasks/README.md",
    "file://.kiro/steering/**/*.md"
  ],
  "welcomeMessage": "Tell me which tasks/<subdir>/ to dispatch from."
}
