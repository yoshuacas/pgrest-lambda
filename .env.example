# pgrest-lambda environment variables
#
# Copy this file to `.env` (or `.env.local`) and fill in the values you
# need. `pgrest-lambda dev` reads both automatically.
#
# Everything below is optional for local dev — `pgrest-lambda dev` will
# start a bundled Postgres container and generate ephemeral secrets if
# they are absent. Pin the secrets in `.env` once you want stable
# apikeys across restarts.

# Database --------------------------------------------------------------

# If unset, `pgrest-lambda dev` starts a Docker Postgres container
# (pgrest-lambda-dev-postgres) on localhost:54322 and uses it. Set this
# to point at any other reachable PostgreSQL.
# DATABASE_URL=postgres://user:pass@host:5432/db

# Secrets (generated if unset; pin for stable apikeys) ------------------

# Signs the anon/service_role apikey JWTs. Must be >= 32 chars.
# JWT_SECRET=replace-me-with-a-random-string-at-least-32-chars

# better-auth's internal cookie/token signing secret. Must be >= 32 chars.
# BETTER_AUTH_SECRET=replace-me-with-a-random-string-at-least-32-chars

# Server ---------------------------------------------------------------

# Override the URL better-auth uses as its baseURL (OAuth callbacks,
# JWKS). Default: http://localhost:<port>.
# BETTER_AUTH_URL=http://localhost:3000

# Set to `false` to disable /rest/v1/_docs (the Scalar UI).
# PGREST_DOCS=true

# Magic link / OAuth (optional) ----------------------------------------

# SES sender address for magic-link emails.
# SES_FROM_ADDRESS=noreply@example.com

# Google OAuth credentials.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
